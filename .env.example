# Скопируй этот файл в .env и заполни значения.

# Токен от @BotFather (обязательно)
BOT_TOKEN=123456:ABC-DEF_your_token_here

# Кто может пользоваться ботом — Telegram ID через запятую.
# Узнать свой ID: напиши боту команду /id.
# Пусто = доступ ВСЕМ (не рекомендуется на публичном сервере).
ALLOWED_USERS=

# Необязательно: CSV со статистикой использования.
# STATS_FILE=/app/data/stats.csv
